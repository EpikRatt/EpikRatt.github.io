---
import { header } from "../consts.ts";

const navItems = [
  { href: "/", label: "About" },
  { href: "/projects", label: "Projects" },
];

const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, "");
const subpath = pathname.match(/[^\/]+/g);
---

<header class="bg-base-300/30 sticky top-0 z-10 grid grid-cols-3 items-center p-4 backdrop-blur-md">
  <div class="justify-self-start">
    <h2><a href="/">{header.logoTitle}</a></h2>
  </div>

  <nav class="flex justify-self-center gap-6">
    {
      navItems.map((item) => {
        const isActive =
          item.href === pathname || item.href === "/" + (subpath?.[0] || "");

        return (
          <a
            href={item.href}
            class={`link no-underline font-medium hover:text-primary ${isActive ? "text-primary border-b-2 border-primary" : ""}`}
          >
            {item.label}
          </a>
        );
      })
    }
  </nav>

  <div class="justify-self-end"></div>
</header>
